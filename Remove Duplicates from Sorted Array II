class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        # If the array has 2 or fewer elements, it's already valid.
        if len(nums) <= 2:
            return len(nums)
        
        # 'k' is the pointer where we write the next valid element.
        # Since at most two duplicates are allowed, the first two elements are always valid.
        k = 2
        
        # Traverse the array starting from the 3rd element
        for i in range(2, len(nums)):
            # If the current element is not equal to the element two positions before 'k',
            # it means we haven't seen it twice yet in our current valid sequence.
            if nums[i] != nums[k - 2]:
                nums[k] = nums[i]
                k += 1
                
        return k
