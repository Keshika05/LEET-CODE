class Solution:
    def jump(self, nums: List[int]) -> int:
        # Edge case: If there's only 1 element, no jumps are needed
        if len(nums) <= 1:
            return 0
            
        jumps = 0
        current_end = 0
        farthest = 0
        
        # We don't need to process the last element because once 
        # current_end reaches or exceeds len(nums) - 1, we are already done.
        for i in range(len(nums) - 1):
            # Update the farthest position we can reach from the current index
            farthest = max(farthest, i + nums[i])
            
            # If we have reached the end of the current jump's reach
            if i == current_end:
                jumps += 1
                current_end = farthest
                
                # If we can already reach the last index, break early
                if current_end >= len(nums) - 1:
                    break
                    
        return jumps
