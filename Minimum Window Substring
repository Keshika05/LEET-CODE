from collections import Counter

class Solution:
    def minWindow(self, s: str, t: str) -> str:
        if not s or not t or len(s) < len(t):
            return ""
        
        # Dictionary to store the frequency of characters in t
        t_count = Counter(t)
        
        # Dictionary to store the frequency of characters in the current window of s
        window_count = {}
        
        # 'required' is the number of unique characters in t that need to be present in the window
        required = len(t_count)
        
        # 'formed' tracks how many unique characters from t have met their required frequency in the current window
        formed = 0
        
        # Pointers for the sliding window
        l, r = 0, 0
        
        # ans tuple: (window length, left pointer, right pointer)
        ans = (float('inf'), None, None)
        
        while r < len(s):
            char = s[r]
            window_count[char] = window_count.get(char, 0) + 1
            
            # If the current character's frequency matches its desired frequency in t, increment 'formed'
            if char in t_count and window_count[char] == t_count[char]:
                formed += 1
                
            # Try to contract the window from the left until it ceases to be 'valid'
            while l <= r and formed == required:
                char = s[l]
                
                # Update the smallest window found so far
                if r - l + 1 < ans[0]:
                    ans = (r - l + 1, l, r)
                    
                # The character at the 'l' pointer is no longer a part of the window
                window_count[char] -= 1
                if char in t_count and window_count[char] < t_count[char]:
                    formed -= 1
                    
                # Move the left pointer forward
                l += 1
                
            # Move the right pointer forward
            r += 1
            
        return "" if ans[0] == float('inf') else s[ans[1] : ans[2] + 1]
